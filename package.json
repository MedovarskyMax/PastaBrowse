{
  "name": "pastabrowse",
  "version": "1.0.0",
  "description": "A chromium based electron browser. Made as a both learning and passion project",
  "main": "src/main.js",
  "scripts": {
    "start": "electron src/main.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win --config.directories.output=dist/win",
    "build:mac": "electron-builder --mac --config.directories.output=dist/mac",
    "build:linux": "electron-builder --linux --config.directories.output=dist/linux"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MedovarskyMax/PastaBrowse.git"
  },
  "keywords": [],
  "author": "Medovarský Max",
  "license": "GPL-2.0",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MedovarskyMax/PastaBrowse/issues"
  },
  "homepage": "https://github.com/MedovarskyMax/PastaBrowse#readme",
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "io.github.medovarskymax.pastabrowse",
    "productName": "PastaBrowse",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "Icons/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "Icons/pasta_icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "Icons/pasta_icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "Icons/pasta_icon.png"
    }
  }
}
